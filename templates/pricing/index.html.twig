{% extends 'base.html.twig' %}

{% block title %}Tarifs - Nos Formules{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-5 text-center">
        <div class="col-lg-8 mx-auto">
            <h1 class="display-4 fw-bold mb-3">Nos Formules</h1>
            <p class="lead text-muted">Choisissez le plan qui correspond le mieux à vos besoins et commencez dès aujourd'hui.</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Basic Plan -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-radius: 20px;">
                <div class="card-body">
                    <h5 class="text-uppercase text-muted fw-bold mb-4" style="letter-spacing: 1px;">Gratuit</h5>
                    <h2 class="display-4 fw-bold mb-4">0€<span class="fs-5 text-muted fw-normal">/mois</span></h2>
                    <ul class="list-unstyled mb-5 text-start">
                        <li class="mb-3"><i class="fas fa-check text-success me-2"></i> Accès standard</li>
                        <li class="mb-3"><i class="fas fa-check text-success me-2"></i> 5 projets par mois</li>
                        <li class="mb-3 text-muted"><i class="fas fa-times me-2"></i> Support prioritaire</li>
                        <li class="text-muted"><i class="fas fa-times me-2"></i> Rapports avancés</li>
                    </ul>
                    <div class="d-grid mt-auto">
                        <button class="btn btn-outline-primary btn-lg rounded-pill">Commencer</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pro Plan (Highligted) -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-lg text-center p-4 position-relative" style="border-radius: 20px; background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); color: white;">
                <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-warning text-dark px-3 py-2 fw-bold" style="font-size: 0.8rem;">RECOMMANDÉ</span>
                <div class="card-body">
                    <h5 class="text-uppercase fw-bold mb-4" style="letter-spacing: 1px; color: rgba(255,255,255,0.7);">Professionnel</h5>
                    <h2 class="display-4 fw-bold mb-4 text-white">29€<span class="fs-5 fw-normal" style="color: rgba(255,255,255,0.7);">/mois</span></h2>
                    <ul class="list-unstyled mb-5 text-start">
                        <li class="mb-3"><i class="fas fa-check text-white me-2"></i> Projets illimités</li>
                        <li class="mb-3"><i class="fas fa-check text-white me-2"></i> Support prioritaire 24/7</li>
                        <li class="mb-3"><i class="fas fa-check text-white me-2"></i> Statistiques avancées</li>
                        <li><i class="fas fa-check text-white me-2"></i> Rapports personnalisés</li>
                    </ul>
                    <div class="d-grid mt-auto">
                        <button class="btn btn-light btn-lg rounded-pill fw-bold text-primary">S'abonner maintenant</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Enterprise Plan -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4" style="border-radius: 20px;">
                <div class="card-body">
                    <h5 class="text-uppercase text-muted fw-bold mb-4" style="letter-spacing: 1px;">Entreprise</h5>
                    <h2 class="display-4 fw-bold mb-4">99€<span class="fs-5 text-muted fw-normal">/mois</span></h2>
                    <ul class="list-unstyled mb-5 text-start">
                        <li class="mb-3"><i class="fas fa-check text-success me-2"></i> Tout du forfait Pro</li>
                        <li class="mb-3"><i class="fas fa-check text-success me-2"></i> API Dédiée</li>
                        <li class="mb-3"><i class="fas fa-check text-success me-2"></i> Gestion d'équipe</li>
                        <li><i class="fas fa-check text-success me-2"></i> Sécurité renforcée</li>
                    </ul>
                    <div class="d-grid mt-auto">
                        <button class="btn btn-outline-primary btn-lg rounded-pill">Nous contacter</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card { transition: transform 0.3s ease; }
    .card:hover { transform: translateY(-10px); }
</style>
{% endblock %}
