{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.name, 'Nom du produit', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Smartphone X'}}) }}
        {{ form_errors(form.name) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Détails du produit...'}}) }}
        {{ form_errors(form.description) }}
    </div>
    <div class="mb-4">
        {{ form_label(form.price, 'Prix (€)', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': '0.00'}}) }}
        {{ form_errors(form.price) }}
    </div>
    <div class="d-grid">
        <button class="btn btn-primary btn-lg shadow-sm">{{ button_label|default('Enregistrer') }}</button>
    </div>
{{ form_end(form) }}
