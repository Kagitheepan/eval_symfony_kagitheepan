{% extends 'base.html.twig' %}

{% block title %}Accueil - Votre Solution de Gestion{% endblock %}

{% block body %}
{# Hero Section #}
<div class="position-relative overflow-hidden p-3 p-md-5 m-md-3 text-center bg-light rounded shadow-sm" 
     style="background-image: url('{{ asset('hero_landing_page_1774280124495.png') }}'); background-size: cover; background-position: center; min-height: 60vh;">
    <div class="col-md-6 p-lg-5 mx-auto my-5 bg-white bg-opacity-75 rounded p-4 shadow">
        <h1 class="display-3 fw-bold text-primary mb-3">Gérez vos produits avec clarté.</h1>
        <p class="lead fw-normal text-dark mb-4">Une interface moderne, rapide et sécurisée pour piloter votre catalogue en temps réel. Découvrez la puissance de Symfony couplée à un design intuitif.</p>
        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
            <a class="btn btn-primary btn-lg px-5 rounded-pill shadow" href="{{ path('app_product') }}">Voir le Catalogue</a>
            {% if not app.user %}
                <a class="btn btn-outline-dark btn-lg px-5 rounded-pill" href="{{ path('app_login') }}">Commencer</a>
            {% endif %}
        </div>
    </div>
</div>

{# Features Section #}
<div class="container px-4 py-5" id="featured-3">
    <h2 class="pb-2 border-bottom fw-bold">Pourquoi choisir notre solution ?</h2>
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        <div class="feature col">
            <div class="feature-icon d-inline-flex align-items-center justify-content-center fs-2 mb-3 text-primary">
                <i class="fas fa-boxes"></i>
            </div>
            <h3 class="fs-2 fw-bold">Catalogue Dynamique</h3>
            <p>Visualisez vos produits en un coup d'œil avec notre interface responsive. Une navigation fluide pour une expérience utilisateur optimale.</p>
            <a href="{{ path('app_product') }}" class="icon-link d-inline-flex align-items-center">
                Explorer
                <i class="fas fa-chevron-right ms-2"></i>
            </a>
        </div>
        <div class="feature col">
            <div class="feature-icon d-inline-flex align-items-center justify-content-center fs-2 mb-3 text-success">
                <i class="fas fa-user-shield"></i>
            </div>
            <h3 class="fs-2 fw-bold">Sécurité Avancée</h3>
            <p>Vos données sont protégées par les derniers standards de sécurité. Seuls les administrateurs habilités peuvent modifier le catalogue.</p>
        </div>
        <div class="feature col">
            <div class="feature-icon d-inline-flex align-items-center justify-content-center fs-2 mb-3 text-info">
                <i class="fas fa-tachometer-alt"></i>
            </div>
            <h3 class="fs-2 fw-bold">Dashboard Admin</h3>
            <p>Un panneau d'administration intuitif intégré directement à votre flux de travail. Ajoutez des produits en quelques clics.</p>
        </div>
    </div>
</div>

{# Call to Action Section #}
<div class="bg-dark text-secondary px-4 py-5 text-center">
    <div class="py-5">
        <h1 class="display-5 fw-bold text-white">Prêt à transformer votre gestion ?</h1>
        <div class="col-lg-6 mx-auto">
            <p class="fs-5 mb-4">Rejoignez-nous dès aujourd'hui et profitez d'un outil performant pour votre entreprise.</p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="{{ path('app_contact') }}" class="btn btn-outline-info btn-lg px-4 me-sm-3 fw-bold">Nous Contacter</a>
                {% if not app.user %}
                    <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg px-4 fw-bold">S'inscrire Maintenant</a>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
    .feature-icon {
        width: 4rem;
        height: 4rem;
        border-radius: .75rem;
        background-color: var(--bs-light);
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
    }
</style>
{% endblock %}
