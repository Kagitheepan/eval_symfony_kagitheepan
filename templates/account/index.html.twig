{% extends 'base.html.twig' %}

{% block title %}Mon Compte - Dashboard{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3 mb-4">
            <div class="card border shadow-sm">
                <div class="card-body text-center py-4">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.firstname }}+{{ app.user.lastname }}&background=0D6EFD&color=fff&size=80" 
                         class="rounded-circle mb-3 border border-3 border-light shadow-sm" alt="Profile">
                    <h5 class="card-title mb-0 fw-bold">{{ app.user.firstname }} {{ app.user.lastname }}</h5>
                    <p class="card-text text-muted small">{{ app.user.email }}</p>
                    <span class="badge bg-primary rounded-pill px-3">Membre Premium</span>
                </div>
                <div class="list-group list-group-flush border-top">
                    <a href="#" class="list-group-item list-group-item-action active d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-home me-2"></i>Vue d'ensemble</span>
                        <span class="badge bg-white text-primary rounded-pill">3</span>
                    </a>    
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-user-circle me-2"></i>Mon Profil</span>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-shopping-cart me-2"></i>Mes Commandes</span>
                        <span class="badge bg-secondary rounded-pill">12</span>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center text-danger">
                        <span><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-9">
            <!-- Breadcrumbs -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Accueil</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                </ol>
            </nav>

            <!-- Alerts Section -->
            <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <strong>Information :</strong> Votre dernière commande a été expédiée ce matin.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <!-- Dashboard Tabs -->
            <ul class="nav nav-tabs mb-4 border-0 border-bottom" id="dashboardTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold border-0 border-bottom border-primary border-3 bg-transparent" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">Aperçu</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold border-0 bg-transparent text-muted" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab">Activité</button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content" id="dashboardTabsContent">
                <!-- Overview Pane -->
                <div class="tab-pane fade show active" id="overview" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100 bg-light">
                                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                                    <h6 class="fw-bold mb-0">Données de Compte</h6>
                                </div>
                                <div class="card-body p-4">
                                    <table class="table table-borderless table-sm mb-0">
                                        <tr>
                                            <td class="text-muted" style="width: 120px;">Utilisateur</td>
                                            <td class="fw-bold">{{ app.user.firstname }} {{ app.user.lastname }}</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Email</td>
                                            <td class="fw-bold">{{ app.user.email }}</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Statut</td>
                                            <td><span class="badge bg-success">Actif</span></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="card-footer bg-transparent border-0 p-4 pt-0">
                                    <button class="btn btn-sm btn-outline-dark">Modifier</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100 text-bg-dark">
                                <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                                    <h6 class="text-white-50 mb-2">Solde Fidélité</h6>
                                    <h2 class="display-5 fw-bold mb-2">450 <span class="fs-6 text-white-50">pts</span></h2>
                                    <div class="progress mb-2" style="height: 6px;" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar bg-primary" style="width: 75%"></div>
                                    </div>
                                    <p class="mb-0 small text-white-50">Prochain palier dans 150 points</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Horizontal Grid of quick stats -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-0">
                                    <div class="row g-0 text-center">
                                        <div class="col-4 border-end py-4">
                                            <h4 class="fw-bold mb-1">12</h4>
                                            <p class="text-muted small mb-0">Commandes</p>
                                        </div>
                                        <div class="col-4 border-end py-4">
                                            <h4 class="fw-bold mb-1">24</h4>
                                            <p class="text-muted small mb-0">Wishlist</p>
                                        </div>
                                        <div class="col-4 py-4">
                                            <h4 class="fw-bold mb-1">3</h4>
                                            <p class="text-muted small mb-0">Coupons</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Activity Pane -->
                <div class="tab-pane fade" id="activity" role="tabpanel">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item p-4 border-0 border-bottom">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 bg-light p-2 rounded text-primary">
                                            <i class="fas fa-box fa-2x"></i>
                                        </div>
                                        <div class="ms-3">
                                            <p class="mb-0 fw-bold">Commande #1234 livrée</p>
                                            <small class="text-muted">Il y a 2 heures</small>
                                        </div>
                                    </div>
                                </li>
                                <li class="list-group-item p-4 border-0">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 bg-light p-2 rounded text-success">
                                            <i class="fas fa-user-check fa-2x"></i>
                                        </div>
                                        <div class="ms-3">
                                            <p class="mb-0 fw-bold">Compte validé avec succès</p>
                                            <small class="text-muted">Hier à 14:30</small>
                                        </div>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom refinement over standard Bootstrap */
    .nav-tabs .nav-link:hover { color: #0D6EFD !important; }
    .nav-tabs .nav-link.active { border-bottom: 3px solid #0D6EFD !important; }
    .card { border-radius: 12px; }
    .list-group-item.active { background-color: #0D6EFD; border-color: #0D6EFD; }
    .breadcrumb-item + .breadcrumb-item::before { content: "›"; color: #adb5bd; }
</style>
{% endblock %}
