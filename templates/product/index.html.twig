{# 
    Page d'affichage public des produits.
    Affiche une grille de produits avec un bouton d'ajout visible uniquement pour les administrateurs.
#}
{% extends 'base.html.twig' %}

{% block title %}Hello ProductController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

    <div class="row mb-5 align-items-center">
        <div class="col-md-6">
            <h1 class="display-5 fw-bold text-dark">Nos Produits</h1>
            <p class="text-muted">Découvrez notre catalogue complet.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <form action="{{ path('app_product') }}" method="get" class="d-flex justify-content-md-end gap-2">
                <div class="input-group" style="max-width: 400px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="q" class="form-control border-start-0" placeholder="Rechercher un produit..." value="{{ searchTerm }}">
                    <button class="btn btn-primary px-4" type="submit">Chercher</button>
                </div>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_product_new') }}" class="btn btn-success px-4 d-flex align-items-center">
                        <i class="fas fa-plus me-2"></i> Dashboard
                    </a>
                {% endif %}
            </form>
        </div>
    </div>

    {% if searchTerm %}
        <div class="mb-4">
            <p class="text-muted">Résultats de recherche pour : <span class="fw-bold text-primary">"{{ searchTerm }}"</span> 
            <a href="{{ path('app_product') }}" class="ms-2 text-decoration-none text-danger">
                <i class="fas fa-times-circle"></i> Effacer
            </a></p>
        </div>
    {% endif %}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row g-4 mt-2">
        {% for product in products %}
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-dark">{{ product.name }}</h5>
                        <p class="card-text text-secondary">{{ product.description|slice(0, 100) ~ (product.description|length > 100 ? '...' : '') }}</p>
                    </div>
                    <div class="card-footer bg-light border-0 d-flex justify-content-between align-items-center py-3">
                        <span class="fs-4 fw-bold text-primary">{{ product.price|number_format(2, ',', ' ') }} €</span>
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3">Détails</button>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="text-center py-5 bg-white rounded shadow-sm">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted fs-5">Aucun produit n'est disponible pour le moment.</p>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
